# Copy this file to .env (or set these as real environment variables on your
# host) for a production deployment. Do NOT commit the real .env.

# A fresh random secret. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-value

# Must be False in production.
DEBUG=False

# Comma-separated hostnames the app is served from (no scheme, no slashes).
# Example for PythonAnywhere:
ALLOWED_HOSTS=yourname.pythonanywhere.com
