# Copy this file to .env (or set these as real environment variables on your
# host) for a production deployment. Do NOT commit the real .env.

# A fresh random secret. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-value

# Must be False in production.
DEBUG=False

# Comma-separated hostnames the app is served from (no scheme, no slashes).
# Example for PythonAnywhere:
ALLOWED_HOSTS=yourname.pythonanywhere.com

# OpenRouter API key for the "Coach" AI fitness chatbot widget. Get one at
# https://openrouter.ai/keys. Without this set, /api/coach/ returns 503 and
# the rest of the app works normally.
OPENROUTER_API_KEY=replace-with-your-openrouter-key

# Optional: override the model used by Coach (must exist on OpenRouter).
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Optional: comma-separated fallback models tried (in order) when the primary
# model's pool is rate-limited. Set to an empty string to disable fallbacks.
OPENROUTER_FALLBACK_MODELS=google/gemma-4-26b-a4b-it:free,meta-llama/llama-3.3-70b-instruct:free
